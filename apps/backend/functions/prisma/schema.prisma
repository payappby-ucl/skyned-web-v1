generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// * ENUMS
enum Gender {
  male
  female
  others
}

enum InstitutionType {
  university
  college
}

enum OwnershipType {
  private
  public
}

enum Currency {
  USD
  CAD
  AUD
  NGN
  EUR
}

enum DegreeLevel {
  undergraduate
  postgraduate
  masters
  diploma
  certificate
}

enum Intakes {
  winter
  fall
  spring
}

enum TokenType {
  verify
  reset
}

model Token {
  id        Int       @default(autoincrement())
  tokenId   String    @id @default(cuid()) @map("token_id")
  token     String    @db.Text
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tokens")
}

