{
  "name": "functions",
  "version": "0.0.1-193",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "pnpm run cp:local && pnpm i && pnpm run generate && tsc && ./cp-yaml && typedoc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy",
    "logs": "firebase functions:log",
    "start:emulators": "firebase use test && cat .env.test > .env && pnpm run rm:lib && pnpm run build && firebase emulators:start",
    "generate": "pnpm dlx prisma generate",
    "test:db:start": "docker compose up -d",
    "test:db:stop": "docker compose down",
    "test:migrate": "pnpm run test:db:start && pnpm dlx prisma migrate dev && pnpm run seed",
    "rm:lib": "rm -rf lib",
    "cp:local": "rm -rf shared && pnpm --filter '@workspace/*' run build && ./cp-local",
    "start:test:server": "pnpm run test:db:start && pnpm run test:migrate",
    "seed": "pnpm dlx prisma db seed",
    "test": "cat .env.test > .env && pnpm run test:migrate && NODE_OPTIONS='--max_old_space_size=8192' node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand && pnpm run test:db:stop",
    "deploy:test": "pnpm run rm:lib && pnpm version prerelease && pnpm run test",
    "deploy:dev": "pnpm run deploy:test && cat .env.dev > .env && firebase use dev && pnpm dlx prisma db push && GOOGLE_APPLICATION_CREDENTIALS=./src/utils/test-service-account.json LOCAL=local pnpm run seed && pnpm run deploy"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/src/index.js",
  "dependencies": {
    "@google-cloud/pubsub": "^5.1.0",
    "@prisma/client": "^6.5.0",
    "@react-email/components": "^0.0.33",
    "@react-email/render": "^1.0.5",
    "@workspace/shared": "file:shared",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "data-urls": "^5.0.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.2",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.6",
    "mime": "3.0.0",
    "nanoid": "3",
    "nodemailer": "^6.10.0",
    "react": "^19.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@firebase/testing": "^0.20.11",
    "@types/cors": "^2.8.17",
    "@types/data-urls": "^3.0.4",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/mime": "3.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.11",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.31.0",
    "firebase": "^11.2.0",
    "firebase-functions-test": "^3.4.1",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.0",
    "typescript": "5.7.3"
  },
  "private": true,
  "prisma": {
    "seed": "ts-node ./src/seed/index.ts"
  }
}
