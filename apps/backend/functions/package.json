{
  "name": "functions",
  "version": "0.0.1-35",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc && ./cp-yaml",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy",
    "logs": "firebase functions:log",
    "start:emulators": "cat .env.test > .env && firebase emulators:start",
    "generate": "pnpm dlx prisma generate",
    "test:db:start": "docker compose up -d",
    "test:db:stop": "docker compose down",
    "test:migrate": "pnpm dlx prisma migrate dev",
    "rm:lib": "rm -rf lib",
    "test": "cat .env.test > .env && pnpm run rm:lib && pnpm run test:db:start && pnpm run test:migrate && pnpm run generate && jest && pnpm run test:db:stop",
    "deploy:test": "pnpm run rm:lib && pnpm version prerelease && pnpm run test && firebase use test && pnpm run deploy",
    "deploy:dev": "pnpm run deploy:test && cat .env.dev > .env && firebase use dev && pnpm run deploy"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/src/index.js",
  "dependencies": {
    "@workspace/firebase": "file:../../../packages/firebase",
    "@prisma/client": "^6.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@skyned/interfaces": "file:../../../packages/interfaces",
    "@firebase/testing": "^0.20.11",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.1.0",
    "jest": "^29.7.0",
    "prisma": "^6.2.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^4.9.0"
  },
  "private": true
}
