// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  output          = "../src/infrastructure/repository/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// * ENUMS
enum DepartmentName {
  Executive
  Marketing
  Admissions
  Communications
  Technical
  Human_Resource
  Quality_Assurance
}

enum Gender {
  Male
  Female
  Others
}

enum TokenType {
  verify
  reset
}

enum InstitutionType {
  university
  college
}

enum OwnershipType {
  private
  public
}

enum Currency {
  USD
  CAD
  AUD
  NGN
  EUR
  GBP
}

enum TuitionFeeType {
  per_year
  per_semester
  full
}

enum Timeframe {
  day
  week
  month
  year
}

enum IntakeStatus {
  open
  closed
  likely_open
}

enum BlogStatus {
  draft
  scheduled
  published
  unpublished
}

// * Daily Metrics
model DailyStats {
  id   Int      @default(autoincrement())
  date DateTime @unique

  // * Schools
  totalSchools  Int     @default(0) @map("total_schools")
  newSchools    Int     @default(0) @map("new_schools")
  activeSchools Int     @default(0) @map("active_schools")
  schoolGrowth  Decimal @default(0) @map("school_growth") @db.Decimal(10, 2)

  // * Programs
  totalPrograms  Int     @default(0) @map("total_programs")
  newPrograms    Int     @default(0) @map("new_programs")
  activePrograms Int     @default(0) @map("active_programs")
  programGrowth  Decimal @default(0) @map("program_growth") @db.Decimal(10, 2)

  // * FAQs
  totalFaqs Int     @default(0) @map("total_faqs")
  newFaqs   Int     @default(0) @map("new_faqs")
  faqGrowth Decimal @default(0) @map("faq_growth") @db.Decimal(10, 2)

  // * Inquiries
  totalInquiries Int     @default(0) @map("total_inquiries")
  newInquiries   Int     @default(0) @map("new_inquiries")
  inquiryGrowth  Decimal @default(0) @map("inquiry_growth") @db.Decimal(10, 2)

  // * Admins
  totalAdmins  Int     @default(0) @map("total_admins")
  newAdmins    Int     @default(0) @map("new_admins")
  activeAdmins Int     @default(0) @map("active_admins")
  adminGrowth  Decimal @default(0) @map("admin_growth") @db.Decimal(10, 2)

  // * Blogs
  totalPosts       Int     @default(0) @map("total_posts")
  publishedPosts   Int     @default(0) @map("published_posts")
  scheduledPosts   Int     @default(0) @map("scheduled_posts")
  draftPosts       Int     @default(0) @map("draft_posts")
  newPosts         Int     @default(0) @map("new_posts")
  postGrowth       Decimal @default(0) @map("post_growth") @db.Decimal(10, 2)
  unpublishedPosts Int     @default(0) @map("unpublished_posts")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([date])
  @@map("daily_stats")
}

model Token {
  id        Int       @default(autoincrement())
  tokenId   String    @id @default(cuid()) @map("token_id")
  token     String    @db.Text
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tokens")
}

model Admin {
  id                 Int     @unique @default(autoincrement())
  adminId            String  @id @unique @map("admin_id") @db.VarChar(256)
  email              String  @unique
  firstName          String  @map("first_name") @db.VarChar(50)
  lastName           String  @map("last_name") @db.VarChar(50)
  middleName         String? @map("middle_name") @db.VarChar(50)
  gender             Gender
  accountSuspended   Boolean @default(false) @map("account_suspended")
  nationality        String  @db.VarChar(3)
  countryOfResidence String  @map("country_of_residence") @db.VarChar(3)
  about              String? @db.Text
  primaryImage       Json    @map("primary_image")
  secondaryImage     Json?   @map("secondary_image")
  socials            Json?
  phoneNumber        Json?   @map("phone_number")
  jobTitle           String  @map("job_title")

  // * Admin Creation
  createdById String? @map("created_by_id") @db.VarChar(256)
  createdBy   Admin?  @relation("adminCreatedBy", fields: [createdById], references: [adminId])
  created     Admin[] @relation("adminCreatedBy")

  // * Department membership and Departments leading
  departments        Department[]
  departmentsLeading Department[] @relation("departmentLead")

  // * Team membership and Teams leading an created
  teams        Team[]
  teamsLeading Team[] @relation("teamLead")
  teamsCreated Team[] @relation("created")

  // * FAQs created
  faqsCreated Faq[]

  // * Activity Logs
  activityLogs ActivityLog[]

  // * Schools created
  schoolsCreated School[]

  // * Accommodations Created
  accommodationsCreated Accommodation[]

  // * Intakes Created
  intakesCreated Intake[]

  // * Programs Created
  programsCreated Program[]

  // * Blogs Created
  blogsCreated      BlogPost[]
  tagsCreated       Tag[]
  categoriesCreated Category[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([accountSuspended])
  @@index([firstName])
  @@index([lastName])
  @@index([gender])
  @@index([createdById])
  @@map("admins")
}

model Department {
  id   Int            @id @default(autoincrement())
  name DepartmentName @unique

  leadId String? @map("lead_id") @db.VarChar(256)
  lead   Admin?  @relation("departmentLead", fields: [leadId], references: [adminId])

  members Admin[]
  teams   Team[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([createdAt])
  @@index([leadId])
  @@map("departments")
}

model Team {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(256)

  leadId String? @map("lead_id") @db.VarChar(256)
  lead   Admin?  @relation("teamLead", fields: [leadId], references: [adminId])

  departmentId Int        @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation("created", fields: [createdById], references: [adminId])

  members Admin[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([departmentId, name])
  @@index([name])
  @@index([createdAt])
  @@index([departmentId])
  @@index([createdById])
  @@index([leadId])
  @@map("teams")
}

// * FAQ
model Faq {
  id Int @id @default(autoincrement())

  question String
  answer   String @db.Text

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([createdById])
  @@map("faqs")
}

// * Inquiry
model Inquiry {
  id Int @id @default(autoincrement())

  name        String
  phoneNumber Json
  email       String
  message     String
  subject     String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("inquiries")
}

// * Admin Activity log
model ActivityLog {
  id Int @id @default(autoincrement())

  adminId Int   @map("admin_id")
  admin   Admin @relation(fields: [adminId], references: [id])

  resource   String
  resourceId Int    @map("resource_id")

  action  String
  message String?

  previousState Json? @map("previous_state")
  currentState  Json? @map("current_state")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([adminId])
  @@map("activity_logs")
}

// * Schools
model School {
  id       Int    @unique @default(autoincrement())
  schoolId String @id @unique @map("school_id")

  logo            Json
  schoolImage     Json            @map("school_image")
  name            String
  slug            String          @unique
  state           String          @db.VarChar(10)
  country         String          @db.VarChar(3)
  city            String
  address         String
  link            String
  institutionType InstitutionType @map("institution_type")
  ownershipType   OwnershipType   @map("ownership_type")
  currency        Currency
  overview        String
  active          Boolean         @default(true)

  // * Used for random generation
  randomKey Float @default(dbgenerated("RANDOM()"))

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  accommodation Accommodation?
  intakes       Intake[]
  programs      Program[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([country])
  @@index([state])
  @@index([active])
  @@index([institutionType])
  @@index([ownershipType])
  @@index([name, active])
  @@index([overview])
  @@index([country, active, institutionType, ownershipType])
  @@index([createdAt])
  @@index([currency])
  @@index([createdById])
  @@map("schools")
}

model Accommodation {
  id Int @id @default(autoincrement())

  description String @db.Text

  schoolId String @unique @map("school_id")
  school   School @relation(fields: [schoolId], references: [schoolId])

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([createdById])
  @@map("accommodations")
}

// * Programs
model Program {
  id        Int    @unique @default(autoincrement())
  programId String @id @default(cuid()) @map("program_id")

  schoolId String @map("school_id")
  school   School @relation(fields: [schoolId], references: [schoolId], onDelete: Cascade)

  // * Used for random generation
  randomKey Float @default(dbgenerated("RANDOM()"))

  name         String
  slug         String
  faculty      String?
  degreeType   String  @map("degree_type")
  overview     String
  description  String  @db.Text
  requirements String? @db.Text

  financialAids String[] @default([]) @map("financial_aids")

  applicationFee         Decimal @map("application_fee") @db.Decimal(10, 2)
  applicationFeeDiscount Decimal @default(0) @map("application_fee_discount") @db.Decimal(5, 2)

  tuitionFee     Decimal        @map("tuition_fee")
  tuitionFeeType TuitionFeeType @default(per_year) @map("tuition_fee_type")

  timeframe Timeframe @default(month)
  duration  Decimal

  minimumEducationLevel  String  @map("minimum_education_level")
  minimumEducationDegree Int     @map("minimum_education_degree")
  minimumEligibilityGpa  Decimal @map("minimum_education_gpa")

  // * Boolean values
  pgwp   Boolean @default(false)
  active Boolean @default(true)

  intakes       Intake[]
  proficiencies EnglishProficiency[]

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([schoolId, slug])
  @@index([name])
  @@index([name, active])
  @@index([active])
  @@index([slug])
  @@index([createdAt])
  @@index([tuitionFee])
  @@index([tuitionFeeType])
  @@index([applicationFee])
  @@index([applicationFeeDiscount])
  @@index([schoolId])
  @@index([createdById])
  @@index([duration])
  @@index([timeframe])
  @@index([faculty])
  @@index([financialAids])
  // @@index([overview])
  @@index([pgwp])
  @@index([minimumEducationLevel])
  @@index([minimumEducationDegree])
  @@index([minimumEligibilityGpa])
  @@index([randomKey])
  @@map("programs")
}

model EnglishProficiency {
  test  String
  score Decimal

  programId String
  program   Program @relation(fields: [programId], references: [programId], onDelete: Cascade)

  @@unique(name: "proficiency", [test, programId])
  @@index([programId])
  @@map("english_proficiencies")
}

model Intake {
  id Int @id @default(autoincrement())

  intake    String
  startDate DateTime?    @map("start_date")
  deadline  DateTime?
  status    IntakeStatus @default(open)

  schoolId String @map("school_id")
  school   School @relation(fields: [schoolId], references: [schoolId], onDelete: Cascade)

  programs Program[]

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([schoolId, intake, startDate, deadline])
  @@index([deadline])
  @@index([createdAt])
  @@index([schoolId])
  @@index([createdById])
  @@map("intakes")
}

model BlogPost {
  id         Int    @id @default(autoincrement())
  blogPostId String @unique @map("blog_post_id")

  title      String
  slug       String @unique
  excerpt    String
  content    String @db.Text
  coverImage Json   @map("cover_image")

  featured    Boolean    @default(false)
  status      BlogStatus @default(draft)
  publishedAt DateTime?  @map("published_at")

  tags       Tag[]
  categories Category[]

  authorId String @map("author_id") @db.VarChar(256)
  author   Admin  @relation(fields: [authorId], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([title])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([featured])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
  @@map("blog_posts")
}

model Tag {
  id   Int    @id @default(autoincrement())
  name String @unique

  posts BlogPost[]

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdById])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("tags")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  posts BlogPost[]

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdById])
  @@index([createdAt])
  @@index([updatedAt])
  @@map("categories")
}

