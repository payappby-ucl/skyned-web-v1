generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  output        = "../src/infrastructure/repository/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// * ENUMS
enum DepartmentName {
  Executive
  Marketing
  Admissions
  Communications
  Technical
  Human_Resource
  Quality_Assurance
}

enum Gender {
  Male
  Female
  Others
}

enum TokenType {
  verify
  reset
}

