model Token {
  id        Int       @default(autoincrement())
  tokenId   String    @id @default(cuid()) @map("token_id")
  token     String    @db.Text
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tokens")
}

model Admin {
  id                 Int     @default(autoincrement())
  adminId            String  @id @unique @map("admin_id") @db.VarChar(256)
  email              String  @unique
  firstName          String  @map("first_name") @db.VarChar(50)
  lastName           String  @map("last_name") @db.VarChar(50)
  middleName         String? @map("middle_name") @db.VarChar(50)
  gender             Gender
  accountSuspended   Boolean @default(false) @map("account_suspended")
  nationality        String  @db.VarChar(3)
  countryOfResidence String  @map("country_of_residence") @db.VarChar(3)
  about              String? @db.Text
  primaryImage       Json    @map("primary_image")
  secondaryImage     Json?   @map("secondary_image")
  socials            Json?
  phoneNumber        Json?   @map("phone_number")
  jobTitle           String  @map("job_title")

  // * Admin Creation
  createdById String? @map("created_by_id") @db.VarChar(256)
  createdBy   Admin?  @relation("adminCreatedBy", fields: [createdById], references: [adminId])
  created     Admin[] @relation("adminCreatedBy")

  // * Department membership and Departments leading
  departments        Department[]
  departmentsLeading Department[] @relation("departmentLead")

  // * Team membership and Teams leading
  teams        Team[]
  teamsLeading Team[] @relation("teamLead")

  // * FAQs created
  faqsCreated Faq[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model Department {
  id   Int            @id @default(autoincrement())
  name DepartmentName @unique

  leadId String? @map("lead_id") @db.VarChar(256)
  lead   Admin?  @relation("departmentLead", fields: [leadId], references: [adminId])

  members Admin[]
  teams   Team[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("departments")
}

model Team {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(256)

  leadId String? @map("lead_id") @db.VarChar(256)
  lead   Admin?  @relation("teamLead", fields: [leadId], references: [adminId])

  departmentId Int        @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])

  members Admin[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([departmentId, name])
  @@map("teams")
}

// * FAQ
model Faq {
  id Int @id @default(autoincrement())

  question String
  answer   String @db.Text

  createdById String @map("created_by_id") @db.VarChar(256)
  createdBy   Admin  @relation(fields: [createdById], references: [adminId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("faqs")
}

// * Inquiry
model Inquiry {
  id Int @id @default(autoincrement())

  name        String
  phoneNumber Json
  email       String
  message     String
  subject     String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("inquiries")
}

