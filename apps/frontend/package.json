{
  "name": "@skyned/frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter \"@workspace/*\" build && node -e \"require('fs').copyFileSync('.env.dev', '.env.local')\" && next dev --turbopack",
    "build": "pnpm --filter \"@workspace/*\" --if-present build && next build",
    "start": "next start",
    "lint": "next lint",
    "structure": "tree -I 'node_modules|.next|.env|.env.dev|.env.prod|.env.local'"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^12.3.0",
    "@next/third-parties": "15.5.2",
    "@tanstack/react-query": "^5.83.0",
    "@workspace/api": "workspace:*",
    "@workspace/shared": "workspace:*",
    "@workspace/ui": "workspace:*",
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "firebase": "^11.2.0",
    "firebase-admin": "^12.6.0",
    "lucide-react": "^0.475.0",
    "next": "15.5.2",
    "next-themes": "^0.4.4",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "schema-dts": "^1.1.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3"
  },
  "nx": {
    "targets": {
      "start": {
        "dependsOn": [
          "build"
        ]
      }
    }
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.12",
      "@types/react-dom": "19.1.9"
    }
  }
}
